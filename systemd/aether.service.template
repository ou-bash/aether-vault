[Unit]
Description=AetherVault Personal Cloud Service
After=network.target tailscaled.service

[Service]
User={{USER}}
Group={{USER}}
Type=simple
WorkingDirectory={{PROJECT_ROOT}}
ExecStart={{PROJECT_ROOT}}/bin/filebrowser -d {{PROJECT_ROOT}}/database/aether.db
EnvironmentFile={{PROJECT_ROOT}}/.env
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
