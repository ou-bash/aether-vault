[Unit]
Description=AetherVault Personal Cloud Service
After=network.target tailscaled.service

[Service]
User=anumoymajhi
Group=anumoymajhi
Type=simple
WorkingDirectory=/home/anumoymajhi/project/project-ssh-cloud/aether-vault
ExecStart=/home/anumoymajhi/project/project-ssh-cloud/aether-vault/bin/filebrowser -d /home/anumoymajhi/project/project-ssh-cloud/aether-vault/database/aether.db
EnvironmentFile=/home/anumoymajhi/project/project-ssh-cloud/aether-vault/.env
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
